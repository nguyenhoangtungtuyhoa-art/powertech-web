@model PowerTech.Models.Entities.Order
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.OrderCode}";
}

<!-- Top Header Section -->
<div class="mb-4">
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small fw-bold text-uppercase" style="letter-spacing: 0.05em;">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Đơn hàng</a></li>
            <li class="breadcrumb-item active text-primary" aria-current="page">Chi tiết</li>
        </ol>
    </nav>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <h1 class="h2 fw-800 mb-1 text-dark">Đơn hàng #@Model.OrderCode</h1>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                <span class="pt-badge @GetStatusBadgeClass(Model.OrderStatus)">
                    <i class="fa-solid fa-circle shadow-sm" style="font-size: 6px;"></i> @GetStatusText(Model.OrderStatus)
                </span>
                <span class="pt-badge @GetPaymentBadgeClass(Model.PaymentStatus)">
                    <i class="fa-solid @(Model.PaymentStatus == "Paid" ? "fa-check-double" : "fa-clock")"></i> @GetPaymentStatusText(Model.PaymentStatus)
                </span>
                <span class="pt-badge bg-light text-dark border">
                    <i class="fa-solid fa-credit-card opacity-50"></i> @Model.PaymentMethod
                </span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-white border px-4 fw-bold shadow-sm">
                <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
            </a>
            <button class="btn btn-primary px-4 fw-bold shadow-sm">
                <i class="fa-solid fa-print me-2"></i> In hóa đơn
            </button>
        </div>
    </div>
</div>

<!-- Summary QuickView -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="order-summary-card shadow-sm border-0">
            <div class="order-summary-icon bg-blue-soft text-primary" style="background: #e0f2fe;">
                <i class="fa-solid fa-wallet"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Tổng thanh toán</div>
                <div class="h4 fw-800 mb-0 text-dark">@Model.TotalAmount.ToString("N0")₫</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="order-summary-card shadow-sm border-0">
            <div class="order-summary-icon text-success" style="background: #f0fdf4;">
                <i class="fa-solid fa-box-archive"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Số lượng SP</div>
                <div class="h4 fw-800 mb-0 text-dark">@Model.OrderItems.Sum(x => x.Quantity) sản phẩm</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="order-summary-card shadow-sm border-0">
            <div class="order-summary-icon text-warning" style="background: #fef3c7;">
                <i class="fa-solid fa-calendar-check"></i>
            </div>
            <div>
                <div class="text-muted small fw-bold text-uppercase">Thời gian tạo</div>
                <div class="h4 fw-800 mb-0 text-dark">@Model.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Center Content -->
    <div class="col-lg-8">
        <!-- Products Table -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header border-0 bg-transparent py-4 ps-4">
                <h5 class="fw-800 mb-0 text-dark"><i class="fa-solid fa-list-ul me-2 text-primary"></i>Danh sách sản phẩm</h5>
            </div>
            <div class="p-0">
                <div class="table-responsive">
                    <table class="table table-modern align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end pe-4">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-light rounded-3 p-1" style="width: 54px; height: 54px;">
                                                <img src="@(string.IsNullOrEmpty(item.Product?.ThumbnailUrl) ? "/images/no-image.png" : item.Product.ThumbnailUrl)" 
                                                     class="w-100 h-100 object-fit-contain rounded-2"/>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark lh-sm mb-1" style="font-size: 14px;">@item.Product?.Name</div>
                                                <div class="text-muted small fw-medium">SKU: <span class="bg-light px-2 rounded">@item.Product?.SKU</span></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end fw-semibold">@item.UnitPrice.ToString("N0")₫</td>
                                    <td class="text-center fw-bold text-secondary">@item.Quantity</td>
                                    <td class="text-end pe-4 fw-800 text-dark">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="bg-light p-4">
                <div class="row justify-content-end">
                    <div class="col-md-5">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted fw-bold small text-uppercase">Tạm tính:</span>
                            <span class="fw-bold text-dark">@Model.Subtotal.ToString("N0")₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted fw-bold small text-uppercase">Phí giao hàng:</span>
                            <span class="fw-bold text-primary">+@Model.ShippingFee.ToString("N0")₫</span>
                        </div>
                        @if(Model.DiscountAmount > 0) {
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted fw-bold small text-uppercase">Giảm giá:</span>
                                <span class="fw-bold text-danger">-@Model.DiscountAmount.ToString("N0")₫</span>
                            </div>
                        }
                        <hr class="my-3 opacity-10">
                        <div class="d-flex justify-content-between">
                            <span class="h5 fw-800 mb-0 text-dark">TỔNG CỘNG:</span>
                            <span class="h4 fw-800 mb-0 text-primary">@Model.TotalAmount.ToString("N0")₫</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Info Grid (Customer & Shipping) -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 bg-transparent py-4 ps-4">
                        <h5 class="fw-800 mb-0"><i class="fa-solid fa-user-circle me-2 text-primary"></i>Khách hàng</h5>
                    </div>
                    <div class="card-body px-4 pt-0 pb-4">
                        <div class="d-flex align-items-center gap-3 mb-4 bg-light p-3 rounded-4">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 48px; height: 48px; font-size: 1.2rem;">
                                @Model.User?.FullName?.Substring(0, 1).ToUpper()
                            </div>
                            <div>
                                <div class="fw-800 text-dark fs-5 lh-1">@Model.User?.FullName</div>
                                <div class="text-muted small">@Model.User?.Email</div>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="text-muted small fw-bold text-uppercase mb-1">Ngày đăng ký</div>
                                <div class="fw-bold text-dark small">@(Model.User != null ? Model.User.CreatedAt.ToString("dd/MM/yyyy") : "N/A")</div>
                            </div>
                            <div class="col-6">
                                <div class="text-muted small fw-bold text-uppercase mb-1">Số đơn hàng</div>
                                <div class="fw-bold text-dark small">12 đơn</div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <a href="#" class="btn btn-sm btn-outline-primary fw-bold w-100 rounded-3">Xem hồ sơ khách hàng</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header border-0 bg-transparent py-4 ps-4">
                        <h5 class="fw-800 mb-0"><i class="fa-solid fa-truck-fast me-2 text-primary"></i>Vận chuyển</h5>
                    </div>
                    <div class="card-body px-4 pt-0 pb-4">
                        <div class="mb-4">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Người nhận</div>
                            <div class="fw-800 text-dark fs-5 lh-1">@Model.ReceiverName</div>
                            <div class="text-primary fw-bold mt-1"><i class="fa-solid fa-phone-volume me-1"></i> @Model.PhoneNumber</div>
                        </div>
                        <hr class="opacity-5 my-3">
                        <div class="mb-3">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Địa chỉ giao hàng</div>
                            <div class="text-dark fw-medium lh-sm">@Model.ShippingAddress</div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Note))
                        {
                            <div class="bg-warning bg-opacity-10 border border-warning border-opacity-25 p-3 rounded-3 mt-3">
                                <div class="text-warning small fw-bold text-uppercase mb-1"><i class="fa-solid fa-message me-1"></i> Ghi chú người mua</div>
                                <div class="text-dark small lh-sm fw-medium italic">"@Model.Note"</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Interaction Panel -->
    <div class="col-lg-4">
        <!-- Action Control Panel -->
        <div class="card border-0 shadow-sm mb-4 overflow-hidden">
            <div class="card-header border-0 bg-transparent py-4 ps-4">
                <h5 class="fw-800 mb-0 text-dark">Tình trạng đơn hàng</h5>
            </div>
            <div class="card-body px-4 pt-0 pb-4">
                <!-- Shipper Payment Verification Card -->
                <div class="p-3 rounded-4 mb-4 @(Model.PaymentStatus == "Paid" ? "bg-success bg-opacity-10 border border-success border-opacity-25" : "bg-light border")">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="small fw-bold text-muted text-uppercase">Xác nhận thanh toán từ Shipper</span>
                        @if (Model.PaymentStatus == "Paid")
                        {
                            <span class="badge bg-success rounded-pill"><i class="fa-solid fa-check me-1"></i> ĐÃ XÁC NHẬN</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill">CHƯA XÁC NHẬN</span>
                        }
                    </div>
                    @if (Model.PaymentStatus == "Paid")
                    {
                        <div class="text-success small fw-medium">
                            <i class="fa-solid fa-circle-check me-1"></i> Hệ thống/Shipper đã ghi nhận giao tiền thành công.
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i> Đơn hàng đang chờ nhân viên giao hàng thu tiền.
                        </div>
                    }
                </div>

                <!-- Visual Stepper -->
                <div class="order-stepper mb-5 ps-2">
                    <div class="step-row completed">
                        <div class="step-indicator"><i class="fa-solid fa-check"></i></div>
                        <div class="step-label">Chờ xác nhận</div>
                    </div>
                    <div class="step-row @(GetStepClass(Model.OrderStatus, "Processing"))">
                        <div class="step-indicator">@Html.Raw(GetStepIcon(Model.OrderStatus, "Processing"))</div>
                        <div class="step-label">Đang xử lý</div>
                    </div>
                    <div class="step-row @(GetStepClass(Model.OrderStatus, "Shipping", "Shipped"))">
                        <div class="step-indicator">@Html.Raw(GetStepIcon(Model.OrderStatus, "Shipping", "Shipped"))</div>
                        <div class="step-label">Đang giao hàng</div>
                    </div>
                    <div class="step-row @(GetStepClass(Model.OrderStatus, "Completed"))">
                        <div class="step-indicator">@Html.Raw(GetStepIcon(Model.OrderStatus, "Completed"))</div>
                        <div class="step-label">Hoàn tất</div>
                    </div>
                </div>

                @{
                    var nextStatus = Model.OrderStatus switch {
                        "Pending" => "Processing",
                        "Processing" => "Shipping",
                        "Shipping" or "Shipped" => "Completed",
                        _ => ""
                    };

                    var btnText = nextStatus switch {
                        "Processing" => "XÁC NHẬN ĐƠN HÀNG",
                        "Shipping" => "XỬ LÝ XONG - GIAO HÀNG",
                        "Completed" => "XÁC NHẬN HOÀN TẤT",
                        _ => "ĐƠN HÀNG ĐÃ KẾT THÚC"
                    };

                    var btnColor = nextStatus switch {
                        "Processing" => "btn-primary",
                        "Shipping" => "bg-indigo text-white",
                        "Completed" => "btn-success",
                        _ => "btn-light disabled"
                    };

                    bool isCompleteLocked = nextStatus == "Completed" && Model.PaymentStatus != "Paid";
                }

                @if (!string.IsNullOrEmpty(nextStatus))
                {
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="@nextStatus" />
                        
                        <button type="submit" class="btn @btnColor w-100 py-3 fw-800 rounded-4 shadow-sm @(isCompleteLocked ? "disabled opacity-50" : "hover-scale")" 
                                id="btnUpdateStatus" @(isCompleteLocked ? "disabled" : "")>
                            <i class="fa-solid fa-circle-arrow-right me-2"></i> @btnText
                        </button>
                        
                        @if (isCompleteLocked)
                        {
                            <div class="bg-danger bg-opacity-10 text-danger small mt-3 p-2 rounded-3 fw-bold text-center border border-danger border-opacity-25">
                                <i class="fa-solid fa-lock me-1"></i> Shipper chưa báo ĐÃ THU TIỀN. Chưa thể hoàn tất đơn này!
                            </div>
                        }
                    </form>
                }
                else if (Model.OrderStatus == "Completed")
                {
                    <div class="pt-success-card">
                        <div class="pt-success-icon">
                            <i class="fa-solid fa-check"></i>
                        </div>
                        <h4 class="fw-800 mb-1">HOÀN TẤT</h4>
                        <p class="small mb-0 opacity-75">Đơn hàng đã giao và thanh toán thành công.</p>
                    </div>
                }
                else if (Model.OrderStatus == "Cancelled")
                {
                    <div class="pt-danger-card">
                        <div class="pt-danger-icon">
                            <i class="fa-solid fa-xmark"></i>
                        </div>
                        <h4 class="fw-800 mb-1">ĐÃ HỦY</h4>
                        <p class="small mb-0 opacity-75">Lý do: @(Model.InternalNote?.Split('|').Last() ?? "Hủy bởi hệ thống")</p>
                    </div>
                }
            </div>
        </div>

        <!-- History Timeline Card -->
        <div class="card border-0 shadow-sm border-top-primary">
            <div class="card-header border-0 bg-transparent py-4 ps-4">
                <h5 class="fw-800 mb-0 text-dark"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Lịch sử hệ thống</h5>
            </div>
            <div class="card-body px-4 pt-0 pb-4">
                <div class="timeline-modern">
                    @foreach (var entry in Model.OrderHistories)
                    {
                        <div class="timeline-item-modern @(entry == Model.OrderHistories.First() ? "active" : "")">
                            <div class="timeline-time">@entry.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</div>
                            <div class="timeline-desc fw-bold text-dark">@entry.Action</div>
                            <div class="text-muted small">@entry.Note</div>
                            <div class="x-small text-primary fw-bold mt-1">Bởi: @entry.PerformedBy</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadgeClass(string status) => status switch {
        "Pending" => "badge-pending",
        "Processing" or "Confirmed" => "badge-processing",
        "Shipped" or "Shipping" => "badge-shipped",
        "Completed" => "badge-success",
        "Cancelled" => "badge-danger",
        _ => "bg-secondary text-white"
    };

    string GetPaymentBadgeClass(string status) => status switch {
        "Paid" => "badge-success",
        "Unpaid" => "badge-pending",
        "Refunded" => "badge-processing",
        "Failed" => "badge-danger",
        _ => "bg-light text-dark"
    };

    string GetStatusText(string status) => status switch {
        "Pending" => "Chờ xác nhận",
        "Processing" => "Đang xử lý",
        "Shipping" or "Shipped" => "Đang giao hàng",
        "Completed" => "Đã hoàn tất",
        "Cancelled" => "Đã hủy",
        _ => status
    };

    string GetPaymentStatusText(string status) => status switch {
        "Paid" => "Đã thanh toán",
        "Unpaid" => "Chưa thanh toán",
        "Failed" => "Thất bại",
        "Refunded" => "Đã hoàn tiền",
        _ => status
    };

    string GetStatusColorSelect(string status) => status switch {
        "Pending" => "text-warning",
        "Processing" => "text-primary",
        "Shipped" or "Shipping" => "text-info",
        "Completed" => "text-success",
        "Cancelled" => "text-danger",
        _ => ""
    };

    string GetStepClass(string currentStatus, params string[] targets) {
        if (targets.Any(t => t == "Processing") && (currentStatus == "Processing" || currentStatus == "Shipping" || currentStatus == "Shipped" || currentStatus == "Completed")) return "completed";
        if (targets.Any(t => t == "Shipping") && (currentStatus == "Shipping" || currentStatus == "Shipped" || currentStatus == "Completed")) return "completed";
        if (targets.Any(t => t == "Completed") && (currentStatus == "Completed")) return "completed";
        
        if (targets.Any(t => t == currentStatus)) return "active";
        return "";
    }

    string GetStepIcon(string currentStatus, params string[] targets) {
        if (GetStepClass(currentStatus, targets) == "completed") return "<i class='fa-solid fa-check'></i>";
        return targets[0].Substring(0, 1);
    }
}

<style>
    :root {
        --admin-primary: #3b82f6;
        --admin-success: #10b981;
        --admin-danger: #ef4444;
        --bg-indigo: #6366f1;
    }

    .bg-indigo { background-color: var(--bg-indigo) !important; }
    .bg-blue-soft { background: #eff6ff; }
    .border-top-primary { border-top: 4px solid var(--admin-primary) !important; }
    .object-fit-contain { object-fit: contain; }
    .breadcrumb-item + .breadcrumb-item::before { content: "•"; color: #cbd5e1; }
    .fw-800 { font-weight: 800; }

    /* Premium Cards */
    .pt-success-card {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border: 1px solid rgba(16, 185, 129, 0.2);
        border-radius: 1.5rem;
        padding: 2.5rem 1.5rem;
        text-align: center;
        color: #065f46;
    }
    .pt-success-icon {
        width: 60px;
        height: 60px;
        background: #10b981;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 1.5rem;
        box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.4);
    }

    .pt-danger-card {
        background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 1.5rem;
        padding: 2.5rem 1.5rem;
        text-align: center;
        color: #991b1b;
    }
    .pt-danger-icon {
        width: 60px;
        height: 60px;
        background: #ef4444;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 1.5rem;
        box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.4);
    }

    /* Order Stepper */
    .order-stepper {
        position: relative;
        padding-left: 20px;
    }
    .step-row {
        position: relative;
        padding-bottom: 2.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }
    .step-row:last-child { padding-bottom: 0; }
    .step-row::after {
        content: '';
        position: absolute;
        left: 17px;
        top: 35px;
        bottom: -5px;
        width: 2px;
        background: #e2e8f0;
        z-index: 1;
    }
    .step-row:last-child::after { display: none; }
    
    .step-indicator {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: white;
        border: 2px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.85rem;
        color: #94a3b8;
        position: relative;
        z-index: 2;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .step-label {
        font-weight: 700;
        color: #64748b;
        font-size: 0.95rem;
        transition: all 0.3s;
    }

    .step-row.completed .step-indicator {
        background: #10b981;
        border-color: #10b981;
        color: white;
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
    }
    .step-row.completed .step-label { color: #059669; }
    .step-row.completed::after { background: #10b981; }

    .step-row.active .step-indicator {
        background: #3b82f6;
        border-color: #3b82f6;
        color: white;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.2);
        animation: pulse-blue 2s infinite;
    }
    .step-row.active .step-label { color: #2563eb; font-size: 1.05rem; }

    @@keyframes pulse-blue {
        0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); }
        100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
    }

    .hover-scale {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-scale:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15) !important;
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/orderHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveOrderUpdate", function (orderId, status, paymentStatus) {
            if (orderId == '@Model.Id') {
                Swal.fire({
                    icon: 'success',
                    title: 'Đơn hàng vừa cập nhật!',
                    text: 'Dữ liệu mới đã được đồng bộ.',
                    showConfirmButton: false,
                    timer: 1500
                }).then(() => {
                    location.reload();
                });
            }
        });

        connection.start().catch(err => console.error("SignalR Error: ", err));
    </script>
}
