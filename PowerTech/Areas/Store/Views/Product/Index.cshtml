@model PowerTech.Models.ViewModels.Store.ProductListViewModel
@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container my-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Store" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Danh mục sản phẩm</li>
        </ol>
    </nav>

    <!-- Category Grid Selection -->
    <div class="category-grid-wrapper">
        <div class="category-grid-title">
            <i class="fa-solid fa-layer-group text-primary"></i> Danh mục sản phẩm
        </div>
        <div class="category-grid">
            @foreach (var cat in Model.Categories.Take(20))
            {
                var iconUrl = !string.IsNullOrEmpty(cat.ImageUrl) 
                    ? cat.ImageUrl 
                    : cat.Slug.ToLower() switch {
                        "laptop" => "/uploads/categories/laptop.jpg",
                        "pc" or "may-tinh-de-ban" or "pc-bo" => "/uploads/categories/pc.jpg",
                        "man-hinh" or "monitor" => "/uploads/categories/monitor.jpg",
                        "mainboard" or "bo-mach-chu" => "/uploads/categories/mainboard.jpg",
                        "cpu" or "vi-xu-ly" => "/uploads/categories/cpu.jpg",
                        "vga" or "card-do-hoa" or "gpu" => "/uploads/categories/gpu.jpg",
                        "ram" or "bo-nho-trong" => "/uploads/categories/ram.jpg",
                        "ssd" or "o-cung" or "storage" or "hdd" => "/uploads/categories/ssd.jpg",
                        "psu" or "nguon" or "nguon-may-tinh" => "/uploads/categories/psu.jpg",
                        "case" or "vong-may-tinh" or "thung-may" => "/uploads/categories/case.jpg",
                        "keyboard" or "ban-phim" => "/uploads/categories/keyboard.jpg",
                        "mouse" or "chuot" => "/uploads/categories/mouse.jpg",
                        "headset" or "tai-nghe" => "/uploads/categories/headset.jpg",
                        "fan" or "tản-nhiệt" or "cooling" => "/uploads/categories/cooling.jpg",
                        "network" or "thiet-bi-mang" or "router" or "wifi" => "/uploads/categories/network.jpg",
                        "software" or "phan-mem" or "windows" or "office" => "/uploads/categories/software.jpg",
                        "accessory" or "phu-kien" or "linh-kien" => "/uploads/categories/accessory.jpg",
                        "speaker" or "loa" or "sound" => "/uploads/categories/speaker.jpg",
                        "camera" or "webcam" => "/uploads/categories/webcam.jpg",
                        "console" or "gaming-gear" or "tay-cam" => "/uploads/categories/console.jpg",
                        "chair" or "ghe-gaming" => "/uploads/categories/chair.jpg",
                        _ => "/images/no-image.jpg"
                    };

                <a asp-action="Index" 
                   asp-route-categoryId="@cat.Id" 
                   asp-route-brandIds="@Model.BrandIds"
                   asp-route-sortOrder="@Model.SortOrder"
                   class="category-grid-item @(Model.CategoryId == cat.Id ? "active" : "")">
                    <div class="cat-icon-wrapper">
                        <img src="@iconUrl" alt="@cat.Name" />
                    </div>
                    <div class="cat-name">@cat.Name</div>
                </a>
            }
        </div>
        @if (Model.CategoryId.HasValue)
        {
            <div class="text-center mt-3">
                <a asp-action="Index" 
                   asp-route-brandIds="@Model.BrandIds" 
                   asp-route-sortOrder="@Model.SortOrder" 
                   class="btn btn-sm btn-outline-secondary">
                    <i class="fa-solid fa-xmark me-1"></i> Xem tất cả danh mục
                </a>
            </div>
        }
    </div>

    <!-- Brand Filter Section (Dynamic) -->
    @if (Model.Brands.Any())
    {
        <div class="brand-filter-wrapper">
            <span class="brand-filter-label">Thương hiệu:</span>
            
            @foreach (var brand in Model.Brands)
            {
                var isActive = Model.BrandIds.Contains(brand.Id);
                var newBrandIds = new List<int>(Model.BrandIds);
                if (isActive) {
                    newBrandIds.Remove(brand.Id);
                } else {
                    newBrandIds.Add(brand.Id);
                }

                <a href="@Url.Action("Index", new { 
                        q = Model.Query, 
                        categoryId = Model.CategoryId, 
                        brandIds = newBrandIds, 
                        sortOrder = Model.SortOrder 
                    })" 
                   class="brand-tag @(isActive ? "active" : "")">
                    @brand.Name
                </a>
            }

            @if (Model.BrandIds.Any())
            {
                <a asp-action="Index" 
                   asp-route-q="@Model.Query" 
                   asp-route-categoryId="@Model.CategoryId" 
                   asp-route-sortOrder="@Model.SortOrder" 
                   class="btn-clear-filters">
                    <i class="fa-solid fa-rotate-left"></i> Bỏ tất cả chọn
                </a>
            }
        </div>
    }

    <div class="row">
        <!-- Main Content (Full Width) -->
        <div class="col-12">
            <!-- Toolbar -->
            <div class="toolbar">
                <div class="search-result-info">
                    @if (Model.CategoryId.HasValue) {
                        var currentCat = Model.Categories.FirstOrDefault(c => c.Id == Model.CategoryId);
                        <span>Danh mục: <strong>@(currentCat?.Name ?? "N/A")</strong></span>
                        <span class="mx-2 text-muted">|</span>
                    }
                    Tìm thấy <strong>@Model.TotalCount</strong> sản phẩm
                    @if (!string.IsNullOrEmpty(Model.Query))
                    {
                        <span> cho từ khóa "@Model.Query"</span>
                    }
                </div>
                <div class="sort-box d-flex align-items-center gap-2">
                    <span class="text-muted small">Sắp xếp:</span>
                    <select class="sort-select" onchange="window.location.href = updateQueryStringParameter(window.location.href, 'sortOrder', this.value)">
                        <option value="featured" selected="@(Model.SortOrder == "featured")">Nổi bật</option>
                        <option value="newest" selected="@(Model.SortOrder == "newest")">Mới nhất</option>
                        <option value="price_asc" selected="@(Model.SortOrder == "price_asc")">Giá tăng dần</option>
                        <option value="price_desc" selected="@(Model.SortOrder == "price_desc")">Giá giảm dần</option>
                    </select>
                </div>
            </div>

            <!-- Products Grid (5 Columns) -->
            @if (Model.Products.Any())
            {
                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
                    @foreach (var product in Model.Products)
                    {
                        <div class="col">
                            <partial name="_ProductCard" model="product" />
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="pagination-custom">
                        @if (Model.CurrentPage > 1)
                        {
                            <a class="page-link-custom" href="@Url.Action("Index", new { page = Model.CurrentPage - 1, q = Model.Query, categoryId = Model.CategoryId, brandIds = Model.BrandIds, sortOrder = Model.SortOrder })">
                                <i class="fa-solid fa-chevron-left"></i>
                            </a>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <a class="page-link-custom @(i == Model.CurrentPage ? "active" : "")" 
                               href="@Url.Action("Index", new { page = i, q = Model.Query, categoryId = Model.CategoryId, brandIds = Model.BrandIds, sortOrder = Model.SortOrder })">
                                @i
                            </a>
                        }

                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <a class="page-link-custom" href="@Url.Action("Index", new { page = Model.CurrentPage + 1, q = Model.Query, categoryId = Model.CategoryId, brandIds = Model.BrandIds, sortOrder = Model.SortOrder })">
                                <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        }
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 bg-white rounded-3 border">
                    <img src="/images/no-image.png" class="mb-3" style="width: 120px; opacity: 0.5;"/>
                    <h5 class="fw-bold">Rất tiếc, không tìm thấy sản phẩm phù hợp</h5>
                    <p class="text-muted">Bạn có thể thử chọn thương hiệu khác hoặc bỏ bớt bộ lọc.</p>
                    <a asp-action="Index" class="btn btn-primary mt-3 px-4">Xem tất cả sản phẩm</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateQueryStringParameter(uri, key, value) {
            var re = new RegExp("([?&])" + key + "=.*?(&|$)", "i");
            var separator = uri.indexOf('?') !== -1 ? "&" : "?";
            if (uri.match(re)) {
                return uri.replace(re, '$1' + key + "=" + value + '$2');
            }
            else {
                return uri + separator + key + "=" + value;
            }
        }
    </script>
}
