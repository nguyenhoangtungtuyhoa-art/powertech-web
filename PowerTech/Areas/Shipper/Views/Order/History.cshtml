@model IEnumerable<PowerTech.Models.Entities.Order>
@{
    ViewData["Title"] = "Lịch sử giao hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-800 mb-0">LỊCH SỬ</h4>
    <div class="dropdown">
        <button class="btn btn-white btn-sm shadow-sm dropdown-toggle rounded-pill px-3" type="button" data-bs-toggle="dropdown">
            Mọi trạng thái
        </button>
        <ul class="dropdown-menu border-0 shadow">
            <li><a class="dropdown-item" href="#">Thành công</a></li>
            <li><a class="dropdown-item" href="#">Đã hủy</a></li>
        </ul>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="fa-solid fa-folder-open fs-1 text-muted opacity-25 mb-3"></i>
        <p class="text-muted small">Bạn chưa có lịch sử giao hàng nào.</p>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card card-shipper border-0 mb-3 @(order.OrderStatus == "Cancelled" ? "opacity-75" : "")">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div class="fw-800 text-dark">#@order.OrderCode</div>
                        <div class="small text-muted">Cập nhật: @order.UpdatedAt?.ToString("HH:mm - dd/MM/yyyy")</div>
                    </div>
                    @if (order.OrderStatus == "Cancelled")
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2">ĐÃ HỦY</span>
                    }
                    else
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">THÀNH CÔNG</span>
                    }
                </div>
                
                <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded-4 mb-3">
                    <div class="text-muted small">Số tiền:</div>
                    <div class="fw-800 text-dark fs-5">@order.TotalAmount.ToString("N0")₫</div>
                </div>

                <div class="d-flex align-items-center gap-2 text-muted small">
                    <i class="fa-solid fa-location-dot"></i>
                    <div class="text-truncate">@order.ShippingAddress</div>
                </div>

                @if (order.OrderStatus == "Cancelled")
                {
                    <div class="mt-3 p-2 bg-danger bg-opacity-10 rounded text-danger x-small italic fw-medium">
                        Lý do: @(order.Note?.Split('|').LastOrDefault() ?? "Không rõ")
                    </div>
                }
            </div>
        </div>
    }
}

<style>
    .x-small { font-size: 11px; }
</style>
