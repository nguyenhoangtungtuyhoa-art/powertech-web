@model IEnumerable<PowerTech.Models.Entities.StockTransaction>

@{
    ViewData["Title"] = "Lịch sử biến động kho";
    Layout = "_WarehouseLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Lịch sử biến động kho</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index">Kho hàng</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Lịch sử</li>
                </ol>
            </nav>
        </div>
        <a asp-controller="StockEntry" asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Nhập kho mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4 alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Thời gian</th>
                            <th>Sản phẩm</th>
                            <th>Loại</th>
                            <th class="text-center">Thay đổi</th>
                            <th class="text-center">Số dư</th>
                            <th>Người thực hiện</th>
                            <th class="pe-4">Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 small">
                                    <div class="fw-medium text-dark">@item.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted small">@item.CreatedAt.ToString("HH:mm:ss")</div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@(item.Product.ThumbnailUrl ?? "/images/no-image.png")" class="rounded-2 me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                        <div>
                                            <div class="fw-bold text-dark lh-sm">@item.Product.Name</div>
                                            <small class="text-muted">SKU: @item.Product.SKU</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-@(item.TransactionType switch {
                                        "IMPORT" => "success",
                                        "EXPORT" or "SALE" => "danger",
                                        "ADJUSTMENT" => "warning text-dark",
                                        "RETURN" => "info",
                                        _ => "secondary"
                                    }) opacity-50 text-dark">@item.TransactionType</span>
                                </td>
                                <td class="text-center fw-bold text-@(item.Quantity >= 0 ? "success" : "danger")">
                                    @(item.Quantity >= 0 ? "+" : "")@item.Quantity
                                </td>
                                <td class="text-center">
                                    <div class="small text-muted mb-1">
                                        <span class="opacity-50 text-decoration-line-through me-1">@item.BeforeQuantity</span>
                                        <i class="bi bi-arrow-right"></i>
                                    </div>
                                    <div class="fw-bold text-primary">@item.AfterQuantity</div>
                                </td>
                                <td>
                                    <div class="fw-medium">@item.PerformedByUser?.FullName</div>
                                    <small class="text-muted">@item.PerformedByUser?.UserName</small>
                                </td>
                                <td class="pe-4 small">
                                    @if (!string.IsNullOrEmpty(item.ReferenceType))
                                    {
                                        <div class="badge bg-light text-dark border mb-1">Ref: @item.ReferenceType</div>
                                    }
                                    <div class="text-muted">@item.Note</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
